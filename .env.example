# Copy to .env and fill in. .env is gitignored.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# Prometheux (Agent 3 — Classifier). Token from the platform "API Keys" page.
PMTX_TOKEN=pmtx-xxxxxxxxxxxxxxxxxxxxxxxx
# Backend URL: substitute your Prometheux org + username.
JARVISPY_URL=https://api.prometheux.ai/jarvispy/{org}/{user}

# ClickHouse Cloud (Agent 4 — Aggregator/Detector)
CLICKHOUSE_HOST=xxxxx.region.gcp.clickhouse.cloud
CLICKHOUSE_PASSWORD=your-default-user-password
# optional overrides:
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_DATABASE=default

# CITEDMD_API_KEY=
